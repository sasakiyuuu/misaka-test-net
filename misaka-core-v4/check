#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

# Keep the RocksDB/bindgen path deterministic on this host unless the caller
# already provided stricter values.
export BINDGEN_EXTRA_CLANG_ARGS="${BINDGEN_EXTRA_CLANG_ARGS:--I/usr/lib/gcc/x86_64-linux-gnu/13/include}"
export CC="${CC:-gcc}"
export CXX="${CXX:-g++}"

echo "=== cargo fmt --check ==="
cargo fmt --all -- --check

echo "=== cargo check --workspace ==="
cargo check --workspace --message-format short

if cargo --list | grep -qE '^    nextest$'; then
  echo "=== cargo nextest (opt-in) available ==="
else
  echo "=== cargo nextest not installed: skipping ==="
fi

if [[ "${MISAKA_RUN_TARGETED_TESTS:-0}" == "1" ]]; then
  echo "=== cargo test -p misaka-node --bin misaka-node --quiet ==="
  cargo test -p misaka-node --bin misaka-node --quiet
fi

if [[ "${MISAKA_RUN_EXTENDED_GATE:-0}" == "1" ]]; then
  echo "=== scripts/dag_release_gate_extended.sh ==="
  bash ./scripts/dag_release_gate_extended.sh
fi

echo "=== checks passed ==="
