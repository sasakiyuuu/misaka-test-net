# MISAKA Network — Node Configuration
# Copy to .env and adjust values

# RPC
MISAKA_RPC_PORT=3000
MISAKA_RPC_API_KEY=          # Required for mainnet; optional for testnet

# Data
MISAKA_DATA_DIR=./misaka-data

# Consensus
MISAKA_VALIDATORS=1
MISAKA_VALIDATOR_INDEX=0
MISAKA_CHAIN_ID=2            # 1=mainnet, 2=testnet

# Faucet (testnet only)
MISAKA_FAUCET_AMOUNT=100000  # base units per request
MISAKA_FAUCET_COOLDOWN=300   # seconds between requests per address

# CORS (comma-separated origins, or * for development)
MISAKA_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
RUST_LOG=info                # trace, debug, info, warn, error
