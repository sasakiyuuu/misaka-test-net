# MISAKA Network — Node Configuration
# Copy to .env and adjust values

# ── RPC ──
MISAKA_RPC_PORT=3001
MISAKA_RPC_AUTH_MODE=required         # required | open (use 'open' only for local dev)
MISAKA_RPC_API_KEY=changeme-generate-a-secret

# ── Data ──
MISAKA_DATA_DIR=./misaka-data

# ── Consensus ──
MISAKA_VALIDATORS=1
MISAKA_VALIDATOR_INDEX=0
MISAKA_CHAIN_ID=2                     # 1=mainnet, 2=testnet

# ── Validator Passphrase ──
# For production, use Docker secrets (docker/secrets/validator_passphrase.txt)
# or MISAKA_VALIDATOR_PASSPHRASE_FILE pointing to a chmod-600 file.
# MISAKA_VALIDATOR_PASSPHRASE=         # NOT recommended for production
# MISAKA_VALIDATOR_PASSPHRASE_FILE=/opt/misaka/.passphrase

# ── Faucet (testnet only) ──
MISAKA_FAUCET_COOLDOWN_SECS=300       # seconds between requests per IP/address
MISAKA_FAUCET_DRIP_AMOUNT=10000000000 # base units per request (10 MISAKA, 9 decimals)
MISAKA_FAUCET_MAX_QUEUE=100           # max pending faucet requests

# ── P2P ──
# NODE_SEEDS=seed1.example.com:6690,seed2.example.com:6690
# NODE_P2P_PORT=6690
# NODE_NARWHAL_PORT=16110

# ── CORS (comma-separated origins, or * for development) ──
MISAKA_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Logging ──
RUST_LOG=info                         # trace, debug, info, warn, error
# MISAKA_LOG_FORMAT=compact            # compact | json
